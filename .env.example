X_TARGET_HANDLE=polymarket
POLL_INTERVAL_SECONDS=60
POLL_JITTER_SECONDS=15
DATA_DIR=./data
DATABASE_URL=sqlite:./data/app.db
HEADLESS=true
LOG_LEVEL=info
API_HOST=127.0.0.1
API_PORT=8787
BROWSER_CHANNEL=chrome

# Vercel/serverless monitoring
# Use a durable Postgres database on Vercel. Vercel Postgres/Supabase/Neon all work.
POSTGRES_URL=postgres://user:password@host:5432/database
# Optional. If set, manual cron calls must send Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=replace-with-random-secret
# X cookies copied from an authenticated browser session. Prefer the full cookie header.
X_COOKIE_HEADER=
X_AUTH_TOKEN=copy-auth_token-cookie-value
X_CSRF_TOKEN=copy-ct0-cookie-value
X_GUEST_TOKEN=
X_BEARER_TOKEN=
# Optional but recommended. Capture from a local logged-in profile request URL containing /UserTweets?.
X_USER_TWEETS_URL=
