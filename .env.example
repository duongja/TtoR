X_TARGET_HANDLE=polymarket
POLL_INTERVAL_SECONDS=60
POLL_JITTER_SECONDS=15
DATA_DIR=./data
DATABASE_URL=sqlite:./data/app.db
HEADLESS=true
LOG_LEVEL=info
API_HOST=127.0.0.1
API_PORT=8787
BROWSER_CHANNEL=chrome

# Vercel/serverless monitoring
# Use a durable Postgres database on Vercel. Vercel Postgres/Supabase/Neon all work.
POSTGRES_URL=postgres://user:password@host:5432/database
# Optional. If set, manual cron calls must send Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=replace-with-random-secret
# X cookies copied from an authenticated browser session. Prefer the full cookie header.
X_COOKIE_HEADER=
X_AUTH_TOKEN=copy-auth_token-cookie-value
X_CSRF_TOKEN=copy-ct0-cookie-value
X_GUEST_TOKEN=
X_BEARER_TOKEN=
# Optional but recommended. Capture from a local logged-in profile request URL containing /UserTweets?.
X_USER_TWEETS_URL=
X_CLIENT_TRANSACTION_ID=
X_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/144.0.0.0 Safari/537.36

# Optional AI memecoin search-signal analysis. This derives search names/tickers only.
AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://share-ai.ckbdev.com
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium
OPENAI_DISABLE_RESPONSE_STORAGE=true
OPENAI_TIMEOUT_MS=30000
AI_MAX_POSTS_PER_POLL=1
MEME_SIGNAL_THRESHOLD=70

# Optional personal Telegram Solana buy bot. Disabled by default.
TRADING_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=replace-with-random-telegram-webhook-secret
TELEGRAM_ALLOWED_USER_IDS=123456789
PUBLIC_BASE_URL=https://your-vercel-project.vercel.app
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WALLET_SECRET_KEY=
JUPITER_API_KEY=
JUPITER_API_BASE_URL=https://api.jup.ag
DEFAULT_SLIPPAGE_BPS=500
MAX_SLIPPAGE_BPS=1000
MAX_PRICE_IMPACT_PCT=15
MIN_SOL_FEE_BALANCE=0.005
MIN_SOL_RESERVE=0.02
MAX_BUY_SOL=1
MAX_BUY_USDC=500
MAX_BUY_USDT=500
TRADE_INTENT_TTL_SECONDS=60
