{
  "name": "polymarket-x-ingestor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "login": "tsx src/cli.ts login",
    "backfill": "tsx src/cli.ts backfill",
    "poll-once": "tsx src/cli.ts poll-once",
    "worker": "tsx src/cli.ts worker",
    "api": "tsx src/cli.ts api",
    "serve": "tsx src/cli.ts serve",
    "telegram:set-webhook": "tsx scripts/setTelegramWebhook.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "cheerio": "^1.0.0",
    "dotenv": "^17.4.2",
    "openai": "^6.38.0",
    "playwright": "^1.45.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "vitest": {
    "test": {
      "environment": "node",
      "deps": {
        "moduleDirectories": [
          "node_modules"
        ]
      },
      "server": {
        "deps": {
          "external": [
            "node:sqlite",
            "sqlite"
          ]
        }
      }
    }
  }
}
